{
  "schema": "motion/1",
  "id": "loop_video_relax",
  "label": "ループ: 動画視聴（前傾・机に寄りかかる）",
  "notes": "video_relax の基本ループ。マスター指示(2026-06-22c): 椅子がリクライニングしないので後傾をやめ、机へ前傾して寄りかかる『だらけ』に。posture=sit_pc_neutral の上に spine/chest を +x で前傾、両前腕を机に置いて上体を預け、頭はやや上げて画面を見る(緩い)。work_normal(直立タイピング)とは前傾＋前腕を机に預ける点で、sleep_desk(完全突っ伏し・閉眼)とは頭を上げ目を開けている点で区別。表情ゆるめ(fun)。duration20=周期5/10整数倍。",
  "category": "loop",
  "tags": ["mode:video_relax", "family:A'"],
  "posture": "sit_pc_neutral",
  "duration": 20,
  "loop": true,
  "fadeIn": 1.0,
  "fadeOut": 1.0,
  "tracks": {
    "spine": { "keys": [ { "t": 0, "e": [0.2, 0, 0] }, { "t": 20, "e": [0.2, 0, 0] } ] },
    "chest": { "keys": [ { "t": 0, "e": [0.12, 0, 0] }, { "t": 20, "e": [0.12, 0, 0] } ] },
    "neck": { "keys": [ { "t": 0, "e": [-0.12, 0, 0] }, { "t": 20, "e": [-0.12, 0, 0] } ] },
    "head": { "keys": [ { "t": 0, "e": [-0.16, 0, 0] }, { "t": 20, "e": [-0.16, 0, 0] } ] },
    "leftUpperArm": { "keys": [ { "t": 0, "e": [0.15, -0.5, 1.3] }, { "t": 20, "e": [0.15, -0.5, 1.3] } ] },
    "rightUpperArm": { "keys": [ { "t": 0, "e": [0.15, 0.5, -1.3] }, { "t": 20, "e": [0.15, 0.5, -1.3] } ] },
    "leftLowerArm": { "keys": [ { "t": 0, "e": [0, -1.15, -0.55] }, { "t": 20, "e": [0, -1.15, -0.55] } ] },
    "rightLowerArm": { "keys": [ { "t": 0, "e": [0, 1.15, 0.55] }, { "t": 20, "e": [0, 1.15, 0.55] } ] },
    "leftHand": { "keys": [ { "t": 0, "e": [0.1, 0, 0] }, { "t": 20, "e": [0.1, 0, 0] } ] },
    "rightHand": { "keys": [ { "t": 0, "e": [0.1, 0, 0] }, { "t": 20, "e": [0.1, 0, 0] } ] }
  },
  "oscillators": [
    { "bone": "chest", "axis": "x", "amp": 0.03, "period": 5 },
    { "bone": "spine", "axis": "x", "amp": 0.018, "period": 5 },
    { "bone": "head", "axis": "y", "amp": 0.03, "period": 10 },
    { "bone": "head", "axis": "z", "amp": 0.018, "period": 10, "phase": 1.5 }
  ],
  "exprCues": [
    { "preset": "small_smile", "at": 2.0, "intensity": 0.35, "fadeIn": 1.5, "hold": 6.0, "fadeOut": 3.0 },
    { "preset": "small_smile", "at": 12.0, "intensity": 0.4, "fadeIn": 1.5, "hold": 4.0, "fadeOut": 2.5 }
  ],
  "gaze": { "keys": [
    { "t": 0, "to": [0, 2] },
    { "t": 6, "to": [5, 4], "move": 0.6 },
    { "t": 13, "to": [-3, 1], "move": 0.6 }
  ] }
}
