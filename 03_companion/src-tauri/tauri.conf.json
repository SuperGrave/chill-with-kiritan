{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tohoku Companion",
  "version": "0.8.7",
  "identifier": "com.tohoku.companion",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tohoku Companion",
        "width": 960,
        "height": 600,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "visible": true,
        "decorations": true,
        "alwaysOnTop": false
      }
    ],
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true,
      "tooltip": "Tohoku Companion"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
